# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URL (critical for email redirect links) ──────────────────────────────
# Must match what's configured in Supabase Dashboard > Auth > URL Configuration
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Brevo (app-triggered emails: welcome, etc.) ──────────────────────────────
# Get your API key from: https://app.brevo.com/settings/keys/api
# Sender email must be verified in Brevo > Senders & IPs > Senders
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Nexus

# NOTE: Supabase auth emails (signup confirmation, password reset, invites)
# are sent through Brevo SMTP configured in the Supabase Dashboard, NOT here.
# These env vars are only for app-triggered emails sent via /api/send-email.
